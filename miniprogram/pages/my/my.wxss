.page-my {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 头像区域 */
.profile-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
}

.avatar-wrap {
  margin-right: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--color-primary);
  color: white;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: white;
}

.phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.membership-badge {
  display: inline-block;
  margin-top: 12rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.membership-badge.pending {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
}

.membership-badge.active {
  background: rgba(16, 185, 129, 0.2);
  color: #10b981;
}

.membership-badge.rejected {
  background: rgba(239, 68, 68, 0.2);
  color: #ef4444;
}

/* 功能卡片 */
.func-card {
  background: white;
  border-radius: 16rpx;
  margin: 20rpx 24rpx;
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.func-item:last-child {
  border-bottom: none;
}

.func-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.func-text {
  flex: 1;
  font-size: 28rpx;
}

.func-arrow {
  color: var(--color-text-muted);
  font-size: 32rpx;
}

/* 退出登录 */
.logout-btn {
  margin: 40rpx 24rpx;
  text-align: center;
  padding: 24rpx;
  background: white;
  border-radius: 12rpx;
  color: var(--color-danger);
  font-size: 28rpx;
}

/* 管理员入口 */
.admin-entry {
  margin: 20rpx 24rpx;
  text-align: center;
  padding: 24rpx;
  background: var(--color-dark);
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 弹窗 */
.qr-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.qr-content {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  width: 560rpx;
}

.qr-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
}

.qr-tip {
  margin-top: 24rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}
