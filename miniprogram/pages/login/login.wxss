.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 40%, #f5f5f7 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  padding-top: 120rpx;
  padding-bottom: 80rpx;
  text-align: center;
  color: white;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.login-form {
  width: 100%;
  padding: 48rpx 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
}

.btn-login {
  margin-top: 16rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.btn-login::after {
  border: none;
}

.login-footer {
  margin-top: 32rpx;
}

.link {
  color: var(--color-primary);
  font-size: 28rpx;
}
