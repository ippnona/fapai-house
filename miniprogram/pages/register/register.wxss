.page-register {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 60rpx 40rpx;
}

.reg-header {
  margin-bottom: 48rpx;
}

.reg-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-dark);
}

.reg-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.reg-form {
  margin-top: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.form-input {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
}

.btn-register {
  margin-top: 16rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
}

.btn-register::after {
  border: none;
}

.reg-footer {
  text-align: center;
  margin-top: 32rpx;
}

.link {
  color: var(--color-primary);
  font-size: 28rpx;
}
