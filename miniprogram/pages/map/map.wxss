.page-map {
  height: 100vh;
  position: relative;
}

.house-map {
  width: 100%;
  height: 100vh;
}

/* 筛选条 */
.map-filter {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  gap: 16rpx;
  z-index: 10;
}

.map-filter-item {
  padding: 14rpx 28rpx;
  background: white;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.map-filter-item.active {
  background: var(--color-primary);
  color: white;
}

/* 底部卡片 */
.bottom-card {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.bottom-card-inner {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.1);
}

.bc-title {
  font-size: 30rpx;
  font-weight: 700;
}

.bc-info {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.meta-dot {
  margin: 0 8rpx;
}

.bc-price {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.bc-auction-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.bc-market-price {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.map-empty {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: var(--color-text-muted);
  font-size: 28rpx;
  z-index: 5;
}
