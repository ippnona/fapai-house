.page-detail {
  padding-bottom: 140rpx;
}

/* 轮播 */
.detail-swiper {
  width: 100%;
  height: 480rpx;
}

.swiper-img {
  width: 100%;
  height: 480rpx;
}

/* 状态横幅 */
.status-banner {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  color: white;
  font-size: 26rpx;
  gap: 16rpx;
}

.status-banner.ongoing { background: var(--color-primary); }
.status-banner.pending { background: var(--color-warning); }
.status-banner.ended, .status-banner.withdrawn { background: var(--color-text-secondary); }
.status-banner.sold { background: var(--color-success); }

.status-text {
  font-weight: 700;
  font-size: 30rpx;
  flex-shrink: 0;
}

.status-platform {
  flex: 1;
}

.status-watches {
  font-size: 22rpx;
  opacity: 0.85;
}

/* 价格卡片 */
.price-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  color: white;
}

.price-main {
  margin-bottom: 20rpx;
}

.price-label-sm {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.price-big {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.price-big .price {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-primary-light);
}

.price-big .price-unit {
  font-size: 28rpx;
  color: var(--color-primary-light);
  margin-left: 8rpx;
}

.price-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.price-item {
  display: flex;
  flex-direction: column;
}

.market-value {
  color: rgba(255, 255, 255, 0.6);
  text-decoration: line-through;
  font-size: 28rpx;
}

.current-value {
  color: var(--color-warning);
  font-weight: 600;
  font-size: 28rpx;
}

.deposit-value {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.discount-bar {
  padding: 12rpx 20rpx;
  background: rgba(233, 69, 96, 0.15);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.discount-num {
  color: var(--color-primary-light);
  font-weight: 700;
  font-size: 30rpx;
}

/* 信息卡片 */
.info-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.info-location {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.info-cell {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.prop-residence {
  color: var(--color-success) !important;
}

.prop-commercial {
  color: var(--color-warning) !important;
}

/* 时间卡片 */
.card-header {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: var(--color-text);
}

.time-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.time-label {
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.time-value {
  color: var(--color-text);
  font-size: 26rpx;
}

.countdown {
  color: var(--color-primary);
  font-weight: 700;
  font-size: 28rpx;
}

.remark-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

/* 风险提示卡片 */
.risk-card {
  background: #fff8e6;
  border: 1rpx solid #f5d89a;
}

.risk-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.risk-icon {
  font-size: 32rpx;
}

.risk-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #b8860b;
}

.risk-content {
  padding: 20rpx;
  background: white;
  border-radius: 8rpx;
  border: 1rpx solid #f0e0b0;
}

.risk-text {
  font-size: 24rpx;
  color: #6b5a2a;
  line-height: 2;
  white-space: pre-line;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 12rpx;
}

.bottom-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.bottom-btn.consult {
  flex: 1;
  background: var(--color-bg);
  color: var(--color-text);
}

.bottom-btn.watch {
  flex: 1.2;
  background: rgba(233, 69, 96, 0.1);
  color: var(--color-primary);
}

.bottom-btn.goto {
  flex: 2;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
}

/* 咨询弹窗 */
.consult-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.consult-content {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  width: 560rpx;
}

.consult-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.qr-code {
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
}

.consult-tip {
  margin-top: 24rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

/* ── 法院公告 ── */
.court-card .court-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-top: 20rpx;
}
.court-card .court-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.court-card .court-item.full {
  grid-column: 1 / -1;
}
.court-card .court-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}
.court-card .court-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.court-card .court-value.warn-text { color: #e67e22; }
.court-card .court-value.sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  font-weight: 400;
}
.tax-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #fff3e0;
  color: #e67e22;
  border-radius: 6rpx;
  font-size: 24rpx;
}
.court-disclaimer {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #bbb;
  text-align: right;
}

/* ── 优缺点 ── */
.pros-cons-card .pros-summary {
  background: #f8f9fb;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}
.pros-cons-body { display: flex; flex-direction: column; gap: 20rpx; }
.pros-cons-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.pros-cons-title.green { color: #27ae60; }
.pros-cons-title.red { color: #e74c3c; }
.pros-item, .cons-item {
  font-size: 24rpx;
  color: #555;
  line-height: 1.7;
  display: flex;
  align-items: flex-start;
}
.pros-dot, .cons-dot {
  flex-shrink: 0;
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* ── 详情页底部计算器按钮 ── */
.bottom-btn.calc {
  background: #f39c12;
  color: white;
}
.bottom-btn.calc-active {
  background: linear-gradient(135deg, #e94560, #c0392b);
}

/* ── 关键信息卡片 ── */
.key-info-card {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
  color: white;
  padding: 24rpx 32rpx;
}
.key-info-grid {
  display: flex;
  justify-content: space-between;
  text-align: center;
  margin-bottom: 20rpx;
}
.key-info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.key-info-item.highlight .key-info-value {
  color: var(--color-primary-light);
  font-size: 40rpx;
}
.key-info-value {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
}
.key-info-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 6rpx;
}
.risk-high { color: #e74c3c !important; }
.risk-low { color: #27ae60 !important; }

/* 平台链接条 */
.platform-link-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 12rpx;
  margin-top: 16rpx;
}
.platform-link-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}
.platform-link-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}
.platform-link-arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.6);
}
