.page-map {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.map-toolbar {
  position: absolute;
  top: 16rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 100;
  display: flex;
  gap: 12rpx;
}

.toolbar-btn {
  flex: 1;
  background: white;
  border-radius: 40rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.map-view {
  flex: 1;
  width: 100%;
}

/* 聚合标签 */
.cluster-summary {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  z-index: 99;
  background: transparent;
}

.cluster-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.cluster-tags {
  display: inline-flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.cluster-tag {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  min-width: 120rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.ct-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text);
}

.ct-total {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--color-primary);
  margin: 4rpx 0;
}

.ct-detail {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.ongoing-dot {
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 4rpx;
}

.upcoming-dot {
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-warning);
  margin: 0 4rpx 0 8rpx;
}

/* 图例 */
.map-legend {
  position: absolute;
  bottom: 200rpx;
  right: 24rpx;
  z-index: 100;
  background: white;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 6rpx;
}

.legend-item:last-child {
  margin-bottom: 0;
}

/* 房源弹窗 */
.house-popup {
  position: absolute;
  bottom: 160rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 101;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 -8rpx 32rpx rgba(0,0,0,0.12);
}

.popup-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.popup-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.popup-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.tag-ongoing { background: rgba(233, 69, 96, 0.1); color: var(--color-primary); }
.tag-pending { background: rgba(255, 165, 0, 0.1); color: var(--color-warning); }
.tag-ended { background: var(--color-bg); color: var(--color-text-secondary); }
.tag-sold { background: rgba(46, 213, 115, 0.1); color: var(--color-success); }

.popup-info {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.popup-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.popup-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.popup-auction {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.popup-market {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.popup-btn {
  text-align: center;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 加载 */
.map-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.15);
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  justify-content: center;
}

.loading-dots text {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: dot-bounce 1.4s infinite ease-in-out both;
}

.loading-dots text:nth-child(1) { animation-delay: -0.32s; }
.loading-dots text:nth-child(2) { animation-delay: -0.16s; }

@keyframes dot-bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}
