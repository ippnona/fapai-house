<view class="page-map">
  <!-- 地图 -->
  <map 
    id="houseMap"
    class="house-map"
    latitude="{{latitude}}" 
    longitude="{{longitude}}" 
    scale="11"
    markers="{{markers}}"
    bindmarkertap="onMarkerTap"
    show-location
  />

  <!-- 筛选条 -->
  <view class="map-filter">
    <view class="map-filter-item {{activeDistrict ? 'active' : ''}}" bindtap="showDistrictPicker">
      {{activeDistrict || '区域'}}
    </view>
    <view class="map-filter-item {{activePriceRange ? 'active' : ''}}" bindtap="showPricePicker">
      {{activePriceRange || '价格'}}
    </view>
  </view>

  <!-- 底部房源卡片 -->
  <view class="bottom-card" wx:if="{{selectedHouse}}">
    <view class="bottom-card-inner" bindtap="goDetail">
      <view class="bc-title">{{selectedHouse.title}}</view>
      <view class="bc-info">
        <text>{{selectedHouse.district}}</text>
        <text class="meta-dot">·</text>
        <text>{{selectedHouse.roomLayout || '-'}}</text>
        <text class="meta-dot">·</text>
        <text>{{selectedHouse.area}}m²</text>
      </view>
      <view class="bc-price">
        <text class="bc-auction-price">起拍 {{formatWan(selectedHouse.auctionStartPrice)}}万</text>
        <text class="bc-market-price">市场 {{formatWan(selectedHouse.marketPrice)}}万</text>
        <text class="bc-status tag tag-{{selectedHouse.status}}">{{statusMap[selectedHouse.status]}}</text>
      </view>
    </view>
  </view>

  <!-- 无数据 -->
  <view class="map-empty" wx:if="{{!loading && markers.length === 0}}">
    <text>暂无地图数据</text>
  </view>
</view>
