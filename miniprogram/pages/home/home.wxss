.page-home {
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg);
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: var(--color-dark);
}

/* Banner 统计 */
.banner-stats {
  display: flex;
  background: var(--color-dark);
  padding: 0 24rpx 24rpx;
  gap: 16rpx;
}

.banner-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.banner-item.ongoing {
  background: rgba(233, 69, 96, 0.15);
  border-color: rgba(233, 69, 96, 0.3);
}

.banner-item.upcoming {
  background: rgba(255, 165, 0, 0.12);
  border-color: rgba(255, 165, 0, 0.25);
}

.banner-num {
  font-size: 48rpx;
  font-weight: 800;
  color: white;
  line-height: 1;
}

.banner-item.ongoing .banner-num {
  color: #ff4466;
}

.banner-item.upcoming .banner-num {
  color: #ffaa33;
}

.banner-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* 房源卡片 - 关注人数 */
.house-watchers {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  background: white;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid var(--color-border);
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 8rpx;
  border-radius: 8rpx;
  background: var(--color-bg);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all 0.2s;
}

.filter-item.active {
  background: rgba(233, 69, 96, 0.1);
  color: var(--color-primary);
}

.filter-arrow {
  font-size: 20rpx;
  margin-left: 4rpx;
}

/* 筛选面板 */
.filter-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
}

.filter-panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.filter-panel-content {
  position: absolute;
  top: 200rpx;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 14rpx 32rpx;
  border-radius: 8rpx;
  background: var(--color-bg);
  font-size: 26rpx;
}

.filter-option .selected {
  color: var(--color-primary);
  font-weight: 600;
}

/* 房源卡片 */
.house-list {
  padding: 16rpx 0;
}

.house-card {
  display: flex;
  margin: 16rpx 24rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.house-img-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.house-img {
  width: 100%;
  height: 100%;
}

.house-status-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  font-size: 20rpx;
}

.house-platform {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
}

.house-platform.ali {
  background: #ff6a00;
}

.house-platform.jd {
  background: #e4393c;
}

/* 房源信息 */
.house-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.house-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.house-location {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-icon {
  font-size: 20rpx;
}

.house-meta {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.meta-dot {
  margin: 0 8rpx;
}

.house-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-top: 8rpx;
}

.auction-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-right: 4rpx;
}

.price {
  color: var(--color-primary);
  font-weight: 700;
  font-size: 32rpx;
}

.price-unit {
  font-size: 22rpx;
  color: var(--color-primary);
}

.market-price {
  display: flex;
  align-items: baseline;
}

.market-value {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.discount-badge {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  background: rgba(233, 69, 96, 0.1);
  color: var(--color-primary);
  font-weight: 600;
}

/* 加载状态 */
.loading-area {
  text-align: center;
  padding: 32rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.no-more {
  color: var(--color-text-muted);
}
