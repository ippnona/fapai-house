<view class="page-register">
  <view class="reg-header">
    <view class="reg-title">创建账号</view>
    <view class="reg-desc">注册后需管理员开通会员权限</view>
  </view>

  <view class="reg-form">
    <view class="form-item">
      <text class="form-icon">📱</text>
      <input class="form-input" type="number" maxlength="11" placeholder="手机号" value="{{phone}}" bindinput="onPhoneInput"/>
    </view>
    <view class="form-item">
      <text class="form-icon">👤</text>
      <input class="form-input" placeholder="昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput"/>
    </view>
    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input class="form-input" password placeholder="设置密码（至少6位）" value="{{password}}" bindinput="onPasswordInput"/>
    </view>
    <view class="form-item">
      <text class="form-icon">🔒</text>
      <input class="form-input" password placeholder="确认密码" value="{{password2}}" bindinput="onPassword2Input"/>
    </view>
    <button class="btn-register" bindtap="doRegister" loading="{{loading}}">注 册</button>
  </view>

  <view class="reg-footer">
    <text class="link" bindtap="goLogin">已有账号？去登录</text>
  </view>
</view>
