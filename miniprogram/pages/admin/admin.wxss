.page-admin {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 数据概览 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 24rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  border-left: 6rpx solid var(--color-primary);
}

.stat-card.warn { border-color: var(--color-warning); }
.stat-card.success { border-color: var(--color-success); }
.stat-card.primary { border-color: #6366f1; }

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-dark);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* Tab */
.admin-tabs {
  display: flex;
  padding: 0 24rpx;
  gap: 0;
  background: white;
  border-bottom: 1rpx solid var(--color-border);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* 筛选 */
.admin-filter {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.filter-btn {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: var(--color-bg);
  color: var(--color-text-secondary);
}

.filter-btn.active {
  background: rgba(233, 69, 96, 0.1);
  color: var(--color-primary);
}

/* 用户卡片 */
.user-card {
  background: white;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--color-primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.user-detail {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.user-phone {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.user-status {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.membership-pending {
  background: rgba(245, 158, 11, 0.1);
  color: var(--color-warning);
}

.membership-active {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success);
}

.membership-rejected {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
}

.user-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  justify-content: flex-end;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.action-btn.approve {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success);
}

.action-btn.reject {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
}

/* 房源管理 */
.add-house-btn {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx dashed var(--color-primary);
  border-radius: 12rpx;
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
}

.house-admin-card {
  background: white;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.ha-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.ha-info {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.ha-price {
  display: block;
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 700;
  margin-top: 8rpx;
}

/* 咨询卡片 */
.contact-card {
  background: white;
  margin: 12rpx 24rpx;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.ct-header {
  display: flex;
  justify-content: space-between;
}

.ct-user {
  font-weight: 600;
  font-size: 28rpx;
}

.ct-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.ct-content {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.ct-phone {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-primary);
}

.empty-hint {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-muted);
}
